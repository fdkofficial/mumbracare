# Copy this to .env.local for local overrides
# In production, set VITE_API_BASE_URL to your backend domain, e.g.:
# VITE_API_BASE_URL=https://api.mumbra.care/api
VITE_API_BASE_URL="http://51.20.91.145:8080/api"

# Google AdSense — get these from https://adsense.google.com
# Publisher ID: AdSense → Account → Account information → Publisher ID
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# Slot ID: AdSense → Ads → By ad unit → (your Display ad unit) → Get code → data-ad-slot
VITE_ADSENSE_SLOT=0000000000
